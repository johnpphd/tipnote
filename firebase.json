{
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/copilotkit", "function": "copilotkit" },
      { "source": "/api/copilotkit/**", "function": "copilotkit" },
      {
        "source": "/.well-known/oauth-authorization-server",
        "function": "mcp"
      },
      { "source": "/.well-known/oauth-protected-resource", "function": "mcp" },
      {
        "source": "/.well-known/oauth-protected-resource/**",
        "function": "mcp"
      },
      { "source": "/authorize", "function": "mcp" },
      { "source": "/token", "function": "mcp" },
      { "source": "/register", "function": "mcp" },
      { "source": "/revoke", "function": "mcp" },
      { "source": "/oauth/**", "function": "mcp" },
      { "source": "/mcp", "function": "mcp" },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "predeploy": ["grep '^VITE_FIREBASE_' .env > functions/.env || true"]
    }
  ]
}
