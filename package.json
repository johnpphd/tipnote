{
  "name": "tipnote",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && pnpm build:functions",
    "build:functions": "pnpm --dir functions build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prettier": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,yml,yaml,md}\"",
    "prettier:fix": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,yml,yaml,md}\"",
    "verify": "pnpm typecheck && pnpm lint && pnpm prettier && pnpm build",
    "preview": "vite preview"
  },
  "dependencies": {
