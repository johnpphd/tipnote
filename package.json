{
  "name": "tipnote",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && yarn build:functions",
    "build:functions": "cd functions && yarn --ignore-engines build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prettier": "prettier --check \"src/**/*.{ts,tsx}\" \"*.json\"",
    "prettier:fix": "prettier --write \"src/**/*.{ts,tsx}\" \"*.json\"",
    "preview": "vite preview"
  },
