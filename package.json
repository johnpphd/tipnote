    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-branded-types": "^0.2.0",
    "eslint-plugin-harness-guardrails": "^0.1.0",
    "eslint-plugin-react-hooks": "^7.1.1",
