# Client-side Firebase config (VITE_ prefix exposes to browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Server-side (Cloud Functions) -- set via firebase functions:secrets:set
# ANTHROPIC_API_KEY (secret)
# BRAVE_SEARCH_API_KEY (secret)
#
# These are auto-derived from FIREBASE_CONFIG in deployed functions:
# projectId, authDomain, storageBucket
#
# Still needed as env vars:
# BASE_URL, FIREBASE_API_KEY, FIREBASE_MESSAGING_SENDER_ID, FIREBASE_APP_ID
